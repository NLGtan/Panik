# Network
BASE_SEPOLIA_RPC_URL=https://base-sepolia.example-rpc.io/v1/YOUR_KEY
CHAIN_ID=84532

# Deployer
DEPLOYER_PRIVATE_KEY=0xyourprivatekey

# Aave V3 Base Sepolia
AAVE_POOL=0x0000000000000000000000000000000000000000
AAVE_POOL_ADDRESSES_PROVIDER=0x0000000000000000000000000000000000000000
AAVE_PROTOCOL_DATA_PROVIDER=0x0000000000000000000000000000000000000000
AAVE_ORACLE=0x0000000000000000000000000000000000000000

# Uniswap V3 Universal Router (Base Sepolia)
UNIVERSAL_ROUTER=0x0000000000000000000000000000000000000000
NONFUNGIBLE_POSITION_MANAGER=0x0000000000000000000000000000000000000000

# Core assets (Base Sepolia)
USDC=0x0000000000000000000000000000000000000000
WETH=0x0000000000000000000000000000000000000000
USDT=0x0000000000000000000000000000000000000000
LINK=0x0000000000000000000000000000000000000000
MOCK_ORACLE=0x0000000000000000000000000000000000000000

# PANIK executor deployment config
STABLE_DEBT_COOLDOWN_SECONDS=3600
SWAP_DEADLINE_BUFFER_SECONDS=300

# Comma-separated lists. Keep list lengths aligned:
# SWAP_ASSETS[i] <-> SWAP_PATHS[i] <-> SWAP_MIN_OUT_BPS[i]
# Path format is Uniswap V3 packed path:
# 0x + tokenIn(20 bytes) + fee(3 bytes) + tokenOut(20 bytes)
SWAP_ASSETS=0x0000000000000000000000000000000000000000
SWAP_PATHS=0x0000000000000000000000000000000000000000000bb80000000000000000000000000000000000000000
SWAP_MIN_OUT_BPS=9500

# Optional debt-buy routes (USDC -> debt token) for USDC-only repay flow.
# If omitted entirely, deploy scripts auto-derive reverse paths from SWAP_PATHS
# and default DEBT_SWAP_MAX_IN_BPS to 12000 (20% max spend buffer).
# DEBT_SWAP_ASSETS[i] <-> DEBT_SWAP_PATHS[i] <-> DEBT_SWAP_MAX_IN_BPS[i]
# DEBT_SWAP_MAX_IN_BPS must be >= 10000.
DEBT_SWAP_ASSETS=
DEBT_SWAP_PATHS=
DEBT_SWAP_MAX_IN_BPS=

# Optional: assets that should force MockPriceOracle pricing
MOCK_ORACLE_ASSETS=

# Optional: additional assets to track for frontend/on-chain scanning.
# This list can include assets with no swap route yet (they will show route-missing).
# Example Base Sepolia Aave reserves:
# USDC, USDT, WBTC, WETH, cbETH, LINK
# TRACKED_ASSETS=0xba50Cd2A20f6DA35D788639E581bca8d0B5d4D5f,0x0a215D8ba66387DCA84B284D18c3B4ec3de6E54a,0x54114591963CF60EF3aA63bEfD6eC263D98145a4,0x4200000000000000000000000000000000000006,0xD171b9694f7A2597Ed006D41f7509aaD4B485c4B,0x810D46F9a9027E28F9B01F75E2bdde839dA61115
TRACKED_ASSETS=

# Optional tooling
TENDERLY_RPC_URL=https://virtual.base-sepolia.rpc.tenderly.co/YOUR_KEY
